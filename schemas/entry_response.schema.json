{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "entry_response_schema.json",
    "$comment": "https://dtsapi.org/specifications/versions/v1.0/#entry-endpoint",
    "type": "object",
    "properties": {
        "@context": {"type": "string"},
        "@id": {"type": "string"},
        "@type": {"type": "string"},
        "dtsVersion": {
            "type": "string",
            "enum": ["1-alpha", "unstable", "1.0"]
        },
        "collection": {"type": "string"},
        "document": {"type": "string"},
        "navigation": {"type": "string"}
    },
    "required": [
        "@context", "@id", "@type", "dtsVersion", "collection", "document", "navigation"
    ]
}
