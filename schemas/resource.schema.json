{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "resource.schema.json",
    "$comment": "https://dtsapi.org/specifications/versions/v1.0/#resource",
    "type": "object",
    "properties": {
        "@id": {
            "type": "string",
            "format": "uri"
        },
        "@type": {
            "type": "string",
            "pattern": "^(Resource)$"
        },
        "collection": {
            "type": "string",
            "format": "uri-template"
        },
        "document": {
            "type": "string",
            "format": "uri-template"
        },
        "navigation": {
            "type": "string",
            "format": "uri-template"
        },
        "citationTrees": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "identifier": {"type": "string" },
                    "@type": {"type": "string" },
                    "citeStructure": {
                        "$ref": "#/$defs/citeStructure"
                    },
                    "description": {"type": "string" }
                },
                "required":[
                    "@type"
                ]
            }
        },
        "mediaTypes": {
            "type": "array",
            "items": { "type": "string" }
        }
    },
    "$defs": {
        "citeStructure": {
            "type": ["array", "null"],
            "items": {
                "type": "object",
                "properties": {
                    "citeType": { "type": "string" },
                    "citeStructure": {
                        "$ref": "#/$defs/citeStructure"
                    }
                }
            }
        }
    },
    "required": ["@id", "@type", "citationTrees", "navigation", "document"]
}